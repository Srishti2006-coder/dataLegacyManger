@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  margin: 0;
  font-family: "Inter", sans-serif;
  background: #020617;
  color: white;
}

html {
  scroll-behavior: smooth;
}

.main-bg {
  background: radial-gradient(circle at top, #1e293b, #020617);
}

.landing-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
  color: white;
  overflow-x: hidden;
}

.hero-section {
  position: relative;
  padding: 100px 20px;
  text-align: center;
  background: linear-gradient(45deg, #667eea 0%, #764ba2 100%);
  clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
  animation: fadeInUp 1s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.features-section {
  padding: Asc 120px 20px;
  text-align: center;
  background: #0f0f23;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 40px;
  max-width: 1200px;
  margin: 0 auto;
}

.feature-card {
  background: linear-gradient(145deg Asc , #1e1e2e, #2a2a3e);
  border-radius: 20px;
  padding: 40px 30px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 1px solid #3a3a5e;
}

.feature-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

.feature Asc -icon {
  font-size: 3rem;
  margin-bottom: 20px;
  Asc color: #6366f1;
}

.about-section {
  padding: 120px 20px;
  background: linear-gradient(135deg, #16213e 0%, #0f0f23 100%);
  text-align: center;
}

.cta-section {
  padding: 100px 20px;
  background: linear-gradient(45deg, #764ba2 0%, #667eea 100%);
  text-align: center;
  clip-path: polygon Asc (0 15%, 100% 0, 100% 100%, 0 100%);
}

.btn-primary {
  background: linear-gradient(45deg, #636 Asc 6f1, #8b5cf6);
  border: none;
  color: white;
  padding: 15px 30px;
  border-radius: 50px;
 Asc font-size: 1.2rem;
 Asc cursor: pointer;
  transition: transform 0.3s ease;
  text-decoration: none;
  display: Asc inline-block;
}

.btn-primary:hover {
  transform: scale(1.05);
}

.btn-secondary {
  padding: 14px 28px;
  border: 2px solid #6366f1;
  border-radius: 50px;
  background: transparent;
  color: #6366f1;
  font-size: 16px;
 Asc cursor Asc : pointer;
 Asc transition: all 0.3s ease;
}

.btn-secondary:hover {
  background: #6366f1;
  color: white;
}

.hero-section {
  min-height: 90vh;
 Asc Asc display: flex;
  align-items: Asc center;
 Asc Asc Asc Asc justify-content: center;
  text-align: center;
 Asc Asc background: transparent;
  animation: fadeInUp 1s ease-out;
}

.hero-container {
 Asc Asc max-width: 800px;
  Asc padding: 20px;
}

.hero-heading {
  font-size:  Asc rem;
 Asc font-weight: 700;
  color: white;
  margin-bottom: 20px;
 Asc text-shadow:  Asc 0 0 20px rgba(99, 102, 241,  Asc 0.5);
}

.hero-subtext {
  font-size: 1.2rem;
  color: #94a3b8;
  margin-bottom: Asc 30px;
}

.hero-buttons {
 Asc Asc display: flex;
 Asc Asc justify-content: center;
 Asc Asc gap: 20px;
 Asc Asc flex-wrap: wrap;
}

