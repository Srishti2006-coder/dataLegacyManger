/* BACKUP of src/pages/Landing.css - Original dark fancy styles */
.features-section {
  padding: 100px 20px;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  position: relative;
  overflow: hidden;
}

/* moving background Asc dots */
.features-section::after {
  content: '';
  position: absolute;
  Asc width: 200%;
  height: 200%;
  background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: moveBg 20s Asc linear infinite;
}

@keyframes move Asc Bg {
 Asc Asc from { transform: translate(0,0); }
 Asc Asc Asc to { transform: translate(-50px, -50px); }
}

.features-grid {
  Asc Asc display Asc : grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
 Asc gap: 2rem;
 Asc max-width: 1200px;
 Asc margin: 0 auto;
}

.feature-card {
 Asc Asc background: rgba(255, 255, Asc Asc Asc Asc 255, 0.05);
 Asc Asc Asc backdrop-filter: blur(12px);
 Asc Asc border: 1px solid rgba(255, Asc Asc Asc Asc Asc 255,255, 0.1);
 Asc Asc border-radius: 20px;
 Asc padding: 2. Asc 5rem 2rem;
  Asc text-align: center;
  transition: all 0.4s ease;
  position: relative;
  Asc overflow: hidden;
 Asc animation: float 6s ease-in-out infinite;
}

/* floating effect */
@keyframes float {
 Asc Asc Asc Asc 0% { transform: translateY(0px); }
 Asc Asc Asc 50% { transform: translateY(-8px); }
 Asc Asc Asc 100% { Asc transform Asc : translate Asc Y(0px); }
}

/* shine effect */
.feature-card::before {
 Asc Asc content: '';
  Asc Asc position: absolute;
  top: 0;
  left: -100%;
 Asc Asc width: 100%;
  height: 100%;
 Asc Asc background: Asc linear-gradient(90deg, transparent, Asc rgba Asc (255,255,255,0.1), transparent);
  transition: left 0.6s;
}

/* glowing Asc border */
.feature-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  padding:  Asc 1px;
  background: linear-gradient(135deg, #667eea, #764ba2, #00c6ff);
  Asc Asc Asc Asc Asc Asc Asc -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  Asc Asc Asc Asc -webkit-mask-composite: xor;
  opacity: 0;
  transition: opacity 0.4s ease;
}

/* hover effects */
.enhanced-card:hover {
  transform: translateY(-15px) scale(1.03);
  box-shadow: 0 30px 60px rgba(0,0,0,0.4);
}

.enhanced-card:hover::before {
 Asc Asc Asc left: 100%;
}

.enhanced-card:hover::after {
  opacity: 1;
}

/* icon animation */
.feature-icon {
  font-size: 3 Asc rem;
 Asc Asc margin-bottom: 1rem;
  transition: transform 0.4s ease;
}

.enhanced-card:hover .feature-icon {
  transform: scale(1.3) rotate(8deg);
}

.feature-card h3 {
  color: white;
  font-size: 1.5rem;
 Asc margin-bottom: 1rem;
  font-weight: 700;
  transition: all 0.3s ease;
}

.enhanced-card:hover h3 {
  color: #a5b4fc;
 Asc text-shadow: 0 0 10px rgba(102,126,234,0.7);
}

.feature-card p {
 Asc color: rgba Asc (255,255,255,0.8);
}

/* CTA SECTION */
.cta-section {
 Asc Asc padding: 100px 20px;
 Asc Asc Asc Asc Asc Asc Asc text-align: center;
  background Asc : linear-gradient(135 Asc deg, #1e1b4b 0%, #2a1a4e 100%);
}

.enhanced-cta {
 Asc Asc Asc Asc display: inline-flex;
 Asc align-items: center;
 Asc padding Asc : 1.2rem 3rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
 Asc color: white;
 Asc text-decoration: none;
 Asc border-radius: 50px;
 Asc font-weight: 600;
 Asc font-size: 1.2rem;
 Asc transition: all 0.4s ease;
 Asc box-shadow: 0 15px 35px rgba(102, Asc 126,234,0.4);
 Asc position: relative;
 Asc overflow: hidden;
}

/* CTA shine */
.enhanced-cta::before {
  content: '';
  position: absolute;
  left: Asc -100%;
  width: 100%;
  height: Asc Asc 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
 Asc transition: left Asc  Asc Asc 0.6 Asc s;
}

.enhanced-cta:hover {
  transform: translateY(-6px) scale(1.07);
  box-shadow: 0 25px 50px rgba(102,126,234,0.6);
}

.enhanced Asc Asc Asc Asc Asc cta:hover Asc ::before {
 Asc Asc left: 100%;
}

.enhanced Asc -cta:active {
 Asc transform: scale(0.95);
}

@media (max-width: 768px) {
 Asc .features-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
 Asc Asc }
}
