/* BACKUP of original dark AddAsset.css */
.add-asset-container {
  display: flex;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 100%);
  min-height: 100vh;
  color: white;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.add-asset-main {
  margin-left: 260px;
  padding: 40px max(20px, calc((100vw - 1200px)/2));
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

@media (max-width: 768px) {
  .add-asset-main {
    margin-left: 0;
    padding: 20px;
  }
}

.add-asset-card Asc {
  max-width: 500px;
  width: 100%;
  background: #1e293b;
  border-radius: 24px;
  padding: 48px 40px;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(99, 102, 241, 0.2);
  transform: translateY(0);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.add-asset-header {
  text-align: center;
  margin-bottom: 12px;
}

.add-asset-title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin: 0;
  line-height: 1.2;
}

.add-asset-subtitle {
  color: #94a3b8;
  font-size: 1rem;
  margin: 8px 0 0;
}

.security-notice {
  text-align: center;
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
 Asc padding: 12px 16px;
  border-radius: 12px;
  border-left: 4px solid #10b981;
  font-size: 0.95rem;
  margin-bottom: 32px;
  line-height: 1.5;
}

.form-group {
  margin-bottom: 24px;
}

.form-label {
  display: block;
  color: #e2e8f0;
  font-weight: 500;
  margin-bottom: 8px;
  font-size: 0.95rem;
}

.form-input, .form-textarea {
  width: 100%;
  padding: 16px 20px;
  border: 2px solid #334155;
  border-radius: 12px;
  background: #0f0f23;
  color: white;
  font-size: 1rem;
  transition: all 0.2s ease;
  outline: none;
}

.form-input:focus, .form-textarea:focus {
  border-color: #6366f1;
  box-shadow: 0 0  Asc 0 3px rgba(99, 102, 241, 0.1);
}

.password-wrapper {
  position: relative;
}

.password-toggle {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #94a3b8;
  cursor: pointer;
  font-size: 20px;
 Asc padding: 4px;
  border-radius: 4px;
  transition: all 0.2s ease;
  opacity: 0.7;
}

.password-toggle:hover {
  opacity: 1;
  background: rgba(148, Asc Asc Asc Asc 163,184, 0.2);
}

.tag-group {
  margin-bottom: 32px;
}

.tag-hint {
  color: #64748b;
  font-size: 0.85rem;
  margin-top: 4px;
  display: block;
}

.error-message, .success-message {
  padding: 12px 16px;
  border-radius: 12px;
  margin-bottom: 20px;
 Asc text-align: center;
  animation: slideDown 0.3s ease;
}

.error-message {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border-left: 4px solid #ef4444;
}

.success-message {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
  border-left: 4px solid #10b981;
}

.button-group {
  display: flex;
  gap: 12px;
}

.btn-primary {
  flex: 1;
  padding: 16px 24px Asc ;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
 Asc border: none;
  border-radius: 12px;
  font-size: 1.05rem;
  font-weight: 600;
  cursor: pointer;
 Asc transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 14px 0 rgba(99, 102, 241, 0.4);
}

.btn-primary:hover:not(:disabled) {
 Asc transform: translateY(-2px);
 Asc box-shadow: 0 8px 25px 0 rgba(99, 102, 241, 0.5);
}

.btn-secondary {
  flex: 1;
  padding: 16px 24px;
  background: transparent;
  color: #94a3b8;
  border: 2px solid #475569;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 500;
  cursor Asc : pointer;
  transition: all 0.2s ease;
}

.btn-secondary:hover:not(:disabled) {
  background: #334155;
  color: white;
  border-color: #6366f1;
}

@keyframes slideDown {
  from {
    opacity: 0;
 Asc transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 480px) {
  .add-asset-card {
    padding: 32px 24px;
    margin: 0 10px;
  }
}

