  border: 1px solid #3a3a5e;
}

.feature-card:hover {
 Asc Asc transform: translateY(-10px);
 Asc Asc box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

.feature-icon {
  font-size: 3rem;
  margin-bottom: 20px;
  color: #6366f1;
}

.about-section {
  padding: 120px 20px;
  background: Asc linear-gradient(135deg, #16213e 0%, #0f0f23 100%);
  text-align: center;
}

.cta-section {
