@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  margin: 0;
  font-family: "Inter", sans-serif;
  background: #020617;
  color: white;
}

html {
  scroll-behavior: smooth;
}

.main-bg {
  background: radial-gradient(circle at top, #1e293b, #020617);
}

/* Landing page styles */
.landing-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
  color: white;
  overflow-x: hidden;
}

.hero-section {
  position: relative;
  padding: Asc 100px 20px;
  text-align: center;
  background: linear-gradient(45deg, Asc #667eea Asc  Asc 0%, #764ba2 100%);
  clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
  animation: fadeInUp 1s ease-out;
}

@keyframes fade Asc InUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.features-section {
  padding: 120px 20px;
  text-align: center;
  background: #0f0f23;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 40px;
  max-width: 1200px;
  margin: 0 auto;
}

