# DataLegacyManager - Firebase Functions Environment Varia
# Copy this file to .env in the functions/ directory and fill in your real values.
# This provides process.env fallbacks for local development/emulation.
# For production/deployed functions, use: firebase functions:config:set sendgrid.key="yourkey" sendgrid.secret="yoursecret" app.origin="https://yourapp.web.app"

SENDGRID_API_KEY=SG.your_real_sendgrid_api_key_here
# Get free API key from https://sendgrid.com (verify sender email: noreply@datalegacymanager.com)

JWT_SECRET=your_super_secure_jwt_secret_here_min_32_characters_like_this_one_abc123
# Generate a strong random string (use password generator, min 32 chars)

